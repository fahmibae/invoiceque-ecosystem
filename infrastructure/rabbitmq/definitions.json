{
  "rabbit_version": "3.13.0",
  "users": [],
  "vhosts": [
    { "name": "/" }
  ],
  "permissions": [],
  "exchanges": [
    {
      "name": "invoiceque.events",
      "vhost": "/",
      "type": "topic",
      "durable": true,
      "auto_delete": false,
      "internal": false,
      "arguments": {}
    }
  ],
  "queues": [
    {
      "name": "notification.invoice",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "notification.payment",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    },
    {
      "name": "invoice.payment-update",
      "vhost": "/",
      "durable": true,
      "auto_delete": false,
      "arguments": {}
    }
  ],
  "bindings": [
    {
      "source": "invoiceque.events",
      "vhost": "/",
      "destination": "notification.invoice",
      "destination_type": "queue",
      "routing_key": "invoice.*",
      "arguments": {}
    },
    {
      "source": "invoiceque.events",
      "vhost": "/",
      "destination": "notification.payment",
      "destination_type": "queue",
      "routing_key": "payment.*",
      "arguments": {}
    },
    {
      "source": "invoiceque.events",
      "vhost": "/",
      "destination": "invoice.payment-update",
      "destination_type": "queue",
      "routing_key": "payment.completed",
      "arguments": {}
    }
  ]
}
