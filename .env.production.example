# ============================================================
# InvoiceQue Production Environment Variables
# Copy to .env.production and fill in real values
# ============================================================

# ── JWT ──
JWT_SECRET=your-super-secret-jwt-key-change-this

# ── RabbitMQ ──
RABBITMQ_PASSWORD=your-rabbitmq-password

# ── Database URLs (Neon Cloud — Singapore) ──
AUTH_DB_URL=postgresql://neondb_owner:xxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
CLIENT_DB_URL=postgresql://neondb_owner:xxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
INVOICE_DB_URL=jdbc:postgresql://ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
INVOICE_DB_USERNAME=neondb_owner
INVOICE_DB_PASSWORD=xxx
PAYMENT_DB_URL=postgresql://neondb_owner:xxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
SUBSCRIPTION_DB_URL=postgresql://neondb_owner:xxx@ep-xxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require

# ── Xendit ──
XENDIT_API_KEY=xnd_production_xxx
XENDIT_CALLBACK_TOKEN=your-callback-token

# ── SMTP (for notification-service) ──
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-gmail-app-password
FROM_EMAIL=your-email@gmail.com
